{
  "manifest_version": 3,
  "name": "네이버 내부링크 도우미",
  "version": "1.0.0",
  "description": "네이버 블로그 내부링크 추천 및 중복 글 감지 도구",

  "action": {
    "default_title": "네이버 내부링크 도우미",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "side_panel": {
    "default_path": "popup.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "host_permissions": [
    "https://blog.naver.com/*",
    "https://naver-linker.onrender.com/*"
  ],

  "permissions": [
    "storage",
    "sidePanel",
    "tabs"
  ],

  "content_scripts": [
    {
      "matches": ["https://blog.naver.com/*"],
      "js": ["content.js"],
      "all_frames": false,
      "run_at": "document_idle"
    }
  ],


  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
